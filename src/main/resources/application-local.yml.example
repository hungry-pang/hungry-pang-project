spring:
  application:
    name: hungry-pang-project-local

  datasource:
    url: jdbc:mysql://localhost:3306/test
    username: root
    password: YOUR_PASSWORD_HERE  # 실제 비밀번호로 변경
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      maximum-pool-size: 10
      minimum-idle: 5
      connection-timeout: 30000

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        use_sql_comments: true
        highlight_sql: true
    open-in-view: false

  output:
    ansi:
      enabled: always

# PortOne 설정
portone:
  api:
    key: ${PORTONE_API_KEY:your_portone_api_key_here}
    secret: ${PORTONE_API_SECRET:your_portone_api_secret_here}
    base-url: ${PORTONE_API_BASE_URL:https://api.portone.io}
    v2-secret: ${PORTONE_V2_API_SECRET:your_portone_v2_api_secret_here}
  test-mode: true

# JWT 설정
jwt:
  secret:
    key: ${JWT_SECRET_KEY:ZGtjbmxka24xMzVkbGtuY2tkbmZqNDM5NzNkbGtuY2syZGxja25kazkzOGVuZjJsa2Zua2RuY2oyMjM0MmxrZG5sd2tyb20=}
  expiration:
    access: 3600000
    refresh: 86400000

# 로깅 레벨 설정
logging:
  level:
    root: INFO
    com.example.hungrypangproject: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE
    org.springframework.web: DEBUG
    com.siot.IamportRestClient: DEBUG
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} - %msg%n"

# 서버 설정
server:
  port: 8080
  error:
    include-message: always
    include-binding-errors: always
    include-stacktrace: on_param
    include-exception: true
